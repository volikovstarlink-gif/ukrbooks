# Google Analytics 4 (optional — leave blank to disable)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Назва сайту
NEXT_PUBLIC_SITE_NAME=UkrBooks
NEXT_PUBLIC_SITE_URL=https://ukrbooks.com.ua

# Google AI Studio (для генерації обкладинок — фаза пізніше)
GOOGLE_AI_API_KEY=

# Шлях до папки з книгами (для API завантаження)
BOOKS_ROOT_DIR=D:\Cursor\Books

# ── Реклама: VAST preroll pod (2 ролика як у rezka-ua.pub) ────
# Single SSP — HilltopAds (Adsterra doesn't support VAST, confirmed by
# their support chat 2026-04-18). Fallback: HouseAd countdown.

# HilltopAds VAST. Signup https://hilltopads.com → Add website →
# Create zone type "VAST" → copy tag URL from HTML-КОД.
NEXT_PUBLIC_HILLTOPADS_VAST_URL=

# Optional: skip button after 15s (rezka-style). '1' = on, '0' = forced.
NEXT_PUBLIC_ADS_SKIP_AFTER_15S=0

# HilltopAds Multitag Banner zones (optional, rotated with Adsterra 300x250).
# Create zones of type Multitag Banner 300x250 / 300x100 in HilltopAds
# dashboard, grab the SDK script <src> attribute and paste here.
NEXT_PUBLIC_HILLTOPADS_BANNER_300X250_SRC=
NEXT_PUBLIC_HILLTOPADS_BANNER_300X100_SRC=

# ── Реклама: Adsterra Display ─────────────────────────────────
# Full Popunder tag URL (not an ID — the JS file URL Adsterra gave you).
NEXT_PUBLIC_ADSTERRA_POPUNDER_SRC=
# 32-char hex zone keys for each banner size.
NEXT_PUBLIC_ADSTERRA_BANNER_728X90_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_300X250_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_320X50_KEY=

# ── House ad (fallback when VAST/Monetag doesn't fill) ────────
# Rendered inside VideoAdGate when no paid ad is available, so the
# user sees something meaningful during the 15-sec gate window.
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/ukrbooks
NEXT_PUBLIC_DONATE_URL=https://send.monobank.ua/jar/ukrbooks
